#!/usr/bin/env bash
# bingo-light hook: send to any webhook URL
# Install: cp this to .bingo/hooks/on-sync-success (or on-conflict)
# Set BINGO_WEBHOOK_URL environment variable

set -euo pipefail

WEBHOOK="${BINGO_WEBHOOK_URL:-}"
[[ -z "$WEBHOOK" ]] && exit 0

DATA=$(cat)
EVENT=$(basename "$0")

curl -s -X POST "$WEBHOOK" \
  -H 'Content-type: application/json' \
  -d '{"event":"'"$EVENT"'","data":'"$DATA"'}' \
  >/dev/null 2>&1 || true
