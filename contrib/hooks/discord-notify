#!/usr/bin/env bash
# bingo-light hook: send Discord notification
# Install: cp this to .bingo/hooks/on-sync-success (or on-conflict)
# Set DISCORD_WEBHOOK_URL environment variable

set -euo pipefail

WEBHOOK="${DISCORD_WEBHOOK_URL:-}"
[[ -z "$WEBHOOK" ]] && exit 0

DATA=$(cat)
EVENT=$(basename "$0")

curl -s -X POST "$WEBHOOK" \
  -H 'Content-type: application/json' \
  -d '{"content":"**bingo-light** ['"$EVENT"']: '"$DATA"'"}' \
  >/dev/null 2>&1 || true
