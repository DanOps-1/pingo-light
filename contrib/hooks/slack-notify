#!/usr/bin/env bash
# bingo-light hook: send Slack notification
# Install: cp this to .bingo/hooks/on-sync-success (or on-conflict)
# Set SLACK_WEBHOOK_URL environment variable
#
# Receives JSON on stdin: {"behind_before":5,"patches_rebased":3}

set -euo pipefail

WEBHOOK="${SLACK_WEBHOOK_URL:-}"
[[ -z "$WEBHOOK" ]] && exit 0

DATA=$(cat)
EVENT=$(basename "$0")

TEXT="*bingo-light* [$EVENT]: $DATA"

curl -s -X POST "$WEBHOOK" \
  -H 'Content-type: application/json' \
  -d '{"text":"'"$TEXT"'"}' \
  >/dev/null 2>&1 || true
